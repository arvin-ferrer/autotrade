# Binance Spot Live Paper Trading Configurations
# Stored in Philippine Peso (PHP) and timezone UTC+8 (PHT)

# (Optional) Discord Webhook URL for rich embed trade notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# Gemini API Key for RAG Sentiment Analysis
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) USD to PHP Conversion rate (e.g. 58.5 Peso per 1 Dollar)
PHP_USD_RATE=58.5
